# 网易云音乐 API Enhanced — 云端环境变量模板
# 复制本文件为 .env 并按需修改，或直接在各平台环境变量面板逐个填写

# ===== 必开：解灰（VIP/灰色歌曲解锁）=====
# 5人小圈子强烈建议开启 true
ENABLE_GENERAL_UNBLOCK=true

# ===== 音质 =====
# 允许无损 FLAC
ENABLE_FLAC=true
# 无损时是否选最高码率（可选，默认 false）
SELECT_MAX_BR=false

# ===== 跨域 =====
# 原生App可设 *；Web类App建议填具体域名（逗号分隔）
CORS_ALLOW_ORIGIN=*

# ===== 随机IP（国内服务器请保持 false）=====
ENABLE_RANDOM_CN_IP=false

# ===== 代理（一般不用，留空即可）=====
ENABLE_PROXY=false
PROXY_URL=

# ===== 音源匹配顺序（解灰用）=====
# 严格按下面顺序匹配：酷我、酷狗、咪咕、QQ
FOLLOW_SOURCE_ORDER=true

# ===== 登录态（可选，仅听个人歌单/云盘需要）=====
# 格式：MUSIC_U=xxxxxx
# NETEASE_COOKIE=
